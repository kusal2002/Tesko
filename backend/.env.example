# PostgreSQL connection string
# Local:      postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Neon (prod): copy the connection string from the Neon dashboard. Use the
#              DIRECT (unpooled) string; it already includes ?sslmode=require.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tesko_db?schema=public"

# Secret used to sign JWT tokens.
# Generate a strong random value, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_secret"

# How long an issued JWT stays valid (optional, defaults to 24h)
JWT_EXPIRES_IN="24h"

# Server port (optional, defaults to 5000)
PORT=5000

# Allowed frontend origin(s) for CORS (optional, defaults to http://localhost:5173).
# Accepts a comma-separated list, e.g. to allow both local and the deployed site:
# CORS_ORIGIN="http://localhost:5173,https://your-site.netlify.app"
CORS_ORIGIN="http://localhost:5173"
