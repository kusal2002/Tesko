# Base URL of the backend REST API.
# Local dev:  http://localhost:5000/api  (default if unset)
# Production: your Render backend URL + /api, e.g.
#             https://tesko-backend.onrender.com/api
# Note: Vite inlines this at BUILD time, so it must be set before `npm run build`
# (set it in the Netlify site's environment variables).
VITE_API_BASE_URL="http://localhost:5000/api"
